<service>
	<id>gotoapp.exe</id>
	<name>goto-app</name>
	<description>Local URL shortener — redirects http://goto/&lt;alias&gt; to saved URLs</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>C:\Users\YOUR_USER\goto_url_shortener\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Users\YOUR_USER\goto_url_shortener\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>goto-app wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>DESKTOP-YOUR_USER</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Users\YOUR_USER\goto_url_shortener</workingdirectory>
</service>